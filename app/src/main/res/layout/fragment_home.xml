<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Hero Section: Major Exam Countdown -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_hero_exam"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_primary_gradient">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"
                        android:text="KỲ THI SẮP TỚI"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_hero_exam_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Thi Tốt nghiệp THPT"
                        android:textColor="@color/white"
                        android:textSize="24sp" />

                    <!-- Countdown Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Days Block -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_countdown_item"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_countdown_days"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="00"
                                android:textColor="@color/white"
                                android:textSize="32sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NGÀY"
                                android:textColor="#B3FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:layout_marginHorizontal="8dp"
                            android:fontFamily="sans-serif-black"/>

                        <!-- Hours Block -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_countdown_item"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_countdown_hours"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="00"
                                android:textColor="@color/white"
                                android:textSize="32sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GIỜ"
                                android:textColor="#B3FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:layout_marginHorizontal="8dp"
                            android:fontFamily="sans-serif-black"/>

                        <!-- Minutes Block -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_countdown_item"
                            android:gravity="center"
                            android:paddingVertical="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_countdown_minutes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:text="00"
                                android:textColor="@color/white"
                                android:textSize="32sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PHÚT"
                                android:textColor="#B3FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>

                    </LinearLayout>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/hero_progress"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="24dp"
                        android:progress="0"
                        app:indicatorColor="@color/white"
                        app:trackColor="#33000000"
                        app:trackCornerRadius="4dp" />

                    <TextView
                        android:id="@+id/tv_next_exam_preview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:text="Tiếp theo: Kiểm tra Toán (15 ngày)"
                        tools:visibility="visible" />

                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pomodoro Card (Updated Design) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface_container_lowest"
            app:cardCornerRadius="32dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_pomodoro_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Pomodoro"
                        android:textColor="@color/on_surface"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_pomodoro_title"
                        android:layout_marginTop="4dp"
                        android:text="Tập trung cao độ cho bài học tiếp theo"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Timer Visual -->
                    <FrameLayout
                        android:layout_width="90dp"
                        android:layout_height="90dp">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/cp_home_pomodoro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:progress="100"
                            app:indicatorColor="@color/primary"
                            app:indicatorSize="80dp"
                            app:trackColor="@color/surface_container_high"
                            app:trackThickness="7dp" />

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_timer"
                            app:tint="@color/primary" />
                    </FrameLayout>

                    <!-- Right Side Action -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_home_start_timer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="12dp"
                            android:text="BẮT ĐẦU HỌC NGAY"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-black"
                            app:cornerRadius="20dp"
                            app:backgroundTint="@color/primary"
                            app:elevation="4dp" />

                        <TextView
                            android:id="@+id/btn_home_timetable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="12dp"
                            android:text="THỜI KHÓA BIỂU"
                            android:textColor="@color/primary"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05"
                            android:padding="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Daily Goal Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_daily_goal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/surface_container_lowest"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/outline_variant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Mục tiêu ngày"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp" />

                <FrameLayout
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_marginTop="16dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/cp_home_plan_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:progress="75"
                        app:indicatorColor="@color/primary"
                        app:indicatorSize="140dp"
                        app:trackColor="@color/surface_container_high"
                        app:trackThickness="12dp"
                        app:trackCornerRadius="6dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_home_plan_stats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="3/4"
                            android:textColor="@color/on_surface"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-bold"
                            android:letterSpacing="0.1"
                            android:text="BÀI HỌC"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="10sp" />
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_badge_secondary"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Sắp hoàn thành!"
                    android:textColor="@color/secondary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tasks Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Kế hoạch hôm nay"
                android:textSize="22sp" />
            <TextView
                android:id="@+id/tv_home_view_all_plans"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Xem tất cả"
                android:textColor="@color/primary"
                android:fontFamily="sans-serif-bold" />
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_home_plans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_plan" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
