<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/timer_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Hiệu ứng pháo hoa khi hoàn thành -->
    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/konfettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar: Logo (Đã loại bỏ icon thừa) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_edit"
                    app:tint="#6200EE" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="sans-serif-black"
                    android:text="Focus"
                    android:textColor="#1A1C1C"
                    android:textSize="20sp"
                    android:letterSpacing="-0.02" />
            </LinearLayout>
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <!-- Nhãn công việc -->
                <TextView
                    android:id="@+id/tv_mode_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Viết nháp bài luận"
                    android:textColor="#7A7488"
                    android:textSize="15sp"
                    android:alpha="0.8" />

                <!-- Đồng hồ khổng lồ (Đã điều chỉnh về 110sp theo yêu cầu) -->
                <TextView
                    android:id="@+id/tv_timer_display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="0dp"
                    android:fontFamily="sans-serif-thin"
                    android:letterSpacing="-0.05"
                    android:text="25:00"
                    android:textColor="#1A1C1C"
                    android:textSize="110sp"
                    android:maxLines="1"
                    android:includeFontPadding="false" />

                <!-- Spacer để đẩy nút xuống dưới -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Bộ điều khiển trung tâm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- Nút Reset -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_reset"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="#FCFCFD"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#EBEBEB"
                        app:strokeWidth="1dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_replay"
                            app:tint="#494456" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Nút Play lớn -->
                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/fab_play_pause"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        app:backgroundTint="#6200EE"
                        app:elevation="4dp"
                        app:fabCustomSize="80dp"
                        app:maxImageSize="40dp"
                        android:src="@drawable/ic_play_arrow"
                        app:tint="@color/white"
                        app:borderWidth="0dp"/>

                    <!-- Nút Xong -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_save_session"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="#FCFCFD"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#EBEBEB"
                        app:strokeWidth="1dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_check"
                            app:tint="#494456" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Lời nhắc nhỏ ở dưới cùng -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Học xong rồi nhớ bấm hoàn thành bạn nhé"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    android:alpha="0.6" />

                <!-- Các thành phần ẩn để giữ logic code -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/timer_progress"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
                <TextView android:id="@+id/tv_quote_text" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tv_quote_author" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tv_label_study_mode" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <View android:id="@+id/mode_pomodoro" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/mode_15_min" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/mode_30_min" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/mode_60_min" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</FrameLayout>
