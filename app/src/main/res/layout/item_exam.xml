<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/surface_container_lowest"
    app:cardCornerRadius="24dp"
    app:strokeWidth="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_exam"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:progress="75"
            app:indicatorSize="64dp"
            app:trackThickness="4dp"
            app:indicatorColor="@color/primary" />

        <ImageView
            android:id="@+id/iv_exam_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_alignStart="@id/progress_exam"
            android:layout_alignEnd="@id/progress_exam"
            android:src="@drawable/ic_school"
            app:tint="@color/primary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/progress_exam"
            android:layout_marginStart="16dp"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_exam_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-bold"
                android:text="Exam Name"
                android:textColor="@color/on_surface"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_exam_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 October, 2024"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_days_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="92"
                android:textColor="@color/primary"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/tv_days_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ngày nữa"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
