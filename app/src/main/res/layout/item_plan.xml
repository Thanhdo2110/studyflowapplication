<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_plan"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/surface_container_lowest"
    app:cardCornerRadius="20dp"
    app:cardElevation="1dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Icon môn học -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/violet_100"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/iv_plan_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_school"
                app:tint="@color/violet_700" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_plan_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-bold"
                android:text="Tên nhiệm vụ"
                android:textColor="@color/on_surface"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_plan_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="45 phút"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Nút Check hoàn thành (Đã cải tiến) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_complete_task"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="Đánh dấu hoàn thành"
            app:icon="@drawable/ic_check_circle_outline"
            app:iconSize="32dp"
            app:iconTint="@color/primary"
            app:rippleColor="@color/primary_fixed" />

        <!-- Nút More Options -->
        <ImageView
            android:id="@+id/iv_plan_more"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_more_vert"
            app:tint="@color/outline" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
